{
    "name": "pytree",
    "icon": "assets/images/icon.png",
    "displayName": "PyTree",
    "description": "Helper extension to visualize inheritance trees for Python classes.",
    "version": "0.0.1",
    "license": "MIT",
    "engines": {
        "vscode": "^1.119.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onLanguage:python"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "pytree.showClassTree",
                "title": "PyTree: Class Tree"
            },
            {
                "command": "pytree.showCompleteClassTree",
                "title": "PyTree: Complete Class Tree"
            },
            {
                "command": "pytree.showProjectTree",
                "title": "PyTree: Project Tree"
            },
            {
                "command": "pytree.pickClasses",
                "title": "PyTree: Pick Classes..."
            }
        ],
        "keybindings": [
            {
                "command": "pytree.showClassTree",
                "key": "ctrl+alt+space",
                "when": "editorTextFocus && editorLangId == python"
            },
            {
                "command": "pytree.showCompleteClassTree",
                "key": "ctrl+alt+t",
                "when": "editorTextFocus && editorLangId == python"
            },
            {
                "command": "pytree.showProjectTree",
                "key": "ctrl+alt+p"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "npm run check-types && npm run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "npm run check-types && npm run lint && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vscode-test",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.107.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "esbuild": "^0.27.1",
        "eslint": "^9.39.1",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.48.1"
    }
}
